pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Run Selenium Tests') {
            steps {
                // Run Maven tests (TestNG + Selenium)
                sh 'mvn clean test'
            }
        }
    }

    post {
        always {
            // Archive JUnit XML results
            junit 'target/surefire-reports/*.xml'

            // Publish TestNG HTML report
            publishHTML([
                allowMissing: false,
                alwaysLinkToLastBuild: true,
                keepAll: true,
                reportDir: 'test-output',       // folder containing index.html
                reportFiles: 'index.html',      // HTML file name
                reportName: 'Selenium Test Report'
            ])

            // Clean workspace (optional)
            cleanWs()
        }
        success {
            echo 'Tests passed!'
        }
        failure {
            echo 'Tests failed!'
        }
    }
}
